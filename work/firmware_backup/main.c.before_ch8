unsigned long CheckSum_hy65_40B(unsigned char*pbuf,unsigned short size)
{
	unsigned long checksum = 0L;
   	unsigned short div,mod,t_div,t_mod;
   	unsigned char*p=(unsigned char*)&checksum;
	div=size>>2;						//div=size/sizeof(long)
        mod=size&(unsigned short)0x03;				//mod=size%sizeof(long)

        for(t_div=0;t_div<div;t_div++)
        	for(t_mod=0;t_mod<4;t_mod++)			//for(t_mod=0;t_mod<sizeof(long);t_mod++)
			p[t_mod]^=pbuf[(t_div<<2)+t_mod];	//p[t_mod]^=pbuf[(t_div*sizeof(long))+t_mod];
        for(t_mod=0;t_mod<mod;t_mod++)
        	p[t_mod]^=pbuf[(t_div<<2)+t_mod];
        return checksum;
}

void initTxBuffer1(void)
{
	int i;
	for(i = 0;i<40;i++)TxBuffer2[0] = 0;
	TxBuffer2[0] = 'Z';
	TxBuffer2[1] = 'D';
	TxBuffer2[2] = 'Y';
	TxBuffer2[3] = 'H';
	
	TxBuffer2[4] = 40;
	TxBuffer2[5] = 0;
	
	TxBuffer2[10] = 0;   //硬件类型与硬件版本号
	TxBuffer2[11] = 1;
	
	TxBuffer2[16] = 0x0F;	//指示硬件类型为应变计
	TxBuffer2[17] = 1;		//指示量程
	TxBuffer2[18] = 0;
	
	TxBuffer2[30] = 0x10; 	//COM口配置之数据位
	TxBuffer2[31] = 1; 		//电量指示，固定配置为1。

	TxBuffer2[32] = 0x0A;	
	TxBuffer2[33] = 0x3F;
}
void initTxBuffer1_(void)
{
	//init回送数据包内容
	TxBuffer2[0] = '6';
	TxBuffer2[1] = '5';
	TxBuffer2[2] = 'R';
	TxBuffer2[3] = 'X';
	TxBuffer2[4] = NodeNumber[0];
	TxBuffer2[5] = NodeNumber[1];
	TxBuffer2[6] = NodeNumber[2];
	TxBuffer2[7] = '0';
	TxBuffer2[8] = 'O';
	TxBuffer2[9] = '+';
	TxBuffer2[0x0A] = '0';
	TxBuffer2[0x0B] = '0';
	TxBuffer2[0x0C] = '0';
	TxBuffer2[0x0D] = '0';
	TxBuffer2[0x0E] = '0';
	TxBuffer2[0x0F] = '0';
	TxBuffer2[0x10] = 0x0F;	//节点类型信息。
}

void AddIDNumberBaudrateInfo(u32 data32)
{
	
	TxBuffer2[12] = (u8)data32 ;
	TxBuffer2[13] = (u8)(data32  >> 8);
	TxBuffer2[14] = (u8)(data32  >> 16);
	TxBuffer2[15] = (u8)(data32  >> 24);
	TxBuffer2[20] = (u8)(groupID + data32 - CurrentChannelNumber);
	TxBuffer2[21] = 0x86;
	TxBuffer2[26] = (u8)UART2_BaudRate;
	TxBuffer2[27] = (u8)(UART2_BaudRate >> 8);
	TxBuffer2[28] = (u8)(UART2_BaudRate >> 16);
	TxBuffer2[29] = (u8)(UART2_BaudRate >> 24);
}

void AddCheckSum(void)
{
	unsigned long checksum = 0;
	checksum = CheckSum_hy65_40B(TxBuffer2 + 10,10);
	checksum ^= CheckSum_hy65_40B(TxBuffer2 + 20,20);
	TxBuffer2[6] = (u8)checksum;
	TxBuffer2[7] = (u8)(checksum >> 8);
	TxBuffer2[8] = (u8)(checksum >> 16);
	TxBuffer2[9] = (u8)(checksum >> 24);
}

void ConstructResp(int CurrentMeasurement)
{
	char tmp[32];
	u8 checksum = 0;
	int i ;
	
	if(CurrentMeasurement >= 0)
	{
		sprintf(tmp, "%06d", CurrentMeasurement);	
		TxBuffer2[9] = '+';
		TxBuffer2[0x0A] = tmp[0];
		TxBuffer2[0x0B] = tmp[1];
		TxBuffer2[0x0C] = tmp[2];
		TxBuffer2[0x0D] = tmp[3];
		TxBuffer2[0x0E] = tmp[4];
		TxBuffer2[0x0F] = tmp[5];
	}
	else
	{
		sprintf(tmp, "%07d", CurrentMeasurement);	
		TxBuffer2[0x9] = tmp[0];
		TxBuffer2[0x0A] = tmp[1];
		TxBuffer2[0x0B] = tmp[2];
		TxBuffer2[0x0C] = tmp[3];
		TxBuffer2[0x0D] = tmp[4];
		TxBuffer2[0x0E] = tmp[5];
		TxBuffer2[0x0F] = tmp[6];
	}
	checksum = 21;	//65RX四个头字符先加进去。
	for(i = 0;i < 13;i++) //求校验和
	{
		checksum = checksum + TxBuffer2[i + 4];
	}
	TxBuffer2[0x11] = checksum;
	Usart_Printf_Len(&huart2,TxBuffer2,18);
}

void ConstructResp2(float CurrentMeasurement)
{
	char tmp[32];
	u8 checksum = 0;
	int i ;
	
	sprintf(tmp, "%+06f", CurrentMeasurement);	
	TxBuffer2[0x9] = tmp[0];
	TxBuffer2[0x0A] = tmp[1];
	TxBuffer2[0x0B] = tmp[2];
	TxBuffer2[0x0C] = tmp[3];
	TxBuffer2[0x0D] = tmp[4];
	TxBuffer2[0x0E] = tmp[5];
	TxBuffer2[0x0F] = tmp[6];
	
	checksum = 21;	//65RX四个头字符先加进去。
	for(i = 0;i < 13;i++) //求校验和
	{
		checksum = checksum + TxBuffer2[i + 4];
	}
	TxBuffer2[0x11] = checksum;
	Usart_Printf_Len(&huart2,TxBuffer2,18);
}

