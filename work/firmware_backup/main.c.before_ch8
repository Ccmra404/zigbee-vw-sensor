void delay_ms(u32 nms)
{
	u32 tmrcnt = uwTick;
	while(1)
	{
		if(uwTick - tmrcnt >= nms)break;
	}
}


char E2PROMWriteFlag = 0;
char E2PROMIndex = 0;
u32 E2PROMAddr[5];
u32 E2PROMData[5];

void EEPROM_WriteByte(uint32_t * addr, uint32_t * data)
{
	int i = 0;
	if(E2PROMWriteFlag)
	{
	    HAL_FLASH_Unlock();
		for(i = 0;i<E2PROMIndex;i++)
		{
		    if (HAL_FLASH_Program(FLASH_TYPEPROGRAMDATA_WORD, addr[i], data[i]) != HAL_OK)
		    {
				HAL_FLASH_Program(FLASH_TYPEPROGRAMDATA_WORD, addr[i], data[i]);
		    }
		}
	    HAL_FLASH_Lock();
		E2PROMWriteFlag = 0;
		E2PROMIndex = 0;
	}
}

