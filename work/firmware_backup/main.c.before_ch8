int SingleMeasure(int * TestValue ,int CN)
{
	int i = 0;
	int j = 0;
	float fCurrentMeasurement = 0;
	u32 tmr = 0;
	//u16 crc16 = 0;
	
	TxBuffer1[0] = 0;
	TxBuffer1[1] = 3;
	TxBuffer1[2] = 0;
	TxBuffer1[3] = 0;
	TxBuffer1[4] = 0;
	TxBuffer1[5] = 0x10;
	TxBuffer1[6] = 0x45;
	TxBuffer1[7] = 0xD7;
	MsgFlag1 = 0;
	Usart_Printf_Len(&huart1,TxBuffer1,8);
	tmr = uwTick;
	
	while(1)
	{
		if(uwTick - tmr >= 6000)
		{
			break;
		} 
		if(mb_usart1_t.rx_end_flg == 1)	
		{
			mb_usart1_t.rx_end_flg = 0;
			if(MsgFlag1 >= 25)	//消息长度要足够
			{
				if(crc16_calc(RxBuffer1,25) == 0)
				{

		//收到的数据字节为 “32 F1 44 3F”
		//按协议说明交换顺序为 “F1 32 3F 44”
		//然后强制转换为 float
		//unsigned char bytes[4] = { 0xF1, 0x32,0x3F,0x44 };
		//float value = *(float*) bytes; //得到value值为764.79596
					j++;
					qj.c[3] = RxBuffer1[5];
					qj.c[2] = RxBuffer1[6];
					qj.c[1] = RxBuffer1[3];
					qj.c[0] = RxBuffer1[4];
					TestValue[0] = (long int)(qj.f * 10 + 0.5);	//Channel1#频率
					qj.c[3] = RxBuffer1[9];
					qj.c[2] = RxBuffer1[10];
					qj.c[1] = RxBuffer1[7];
					qj.c[0] = RxBuffer1[8];
					TestValue[1] = (long int)(qj.f * 10 + 0.5);	//Channel2#频率
					qj.c[3] = RxBuffer1[13];
					qj.c[2] = RxBuffer1[14];
					qj.c[1] = RxBuffer1[11];
					qj.c[0] = RxBuffer1[12];
					TestValue[2] = (long int)(qj.f * 10 + 0.5);	//Channel3#频率
					qj.c[3] = RxBuffer1[17];
					qj.c[2] = RxBuffer1[18];
					qj.c[1] = RxBuffer1[15];
					qj.c[0] = RxBuffer1[16];
					TestValue[3] = (long int)(qj.f * 10 + 0.5);	//Channel4#频率

					qj.c[3] = RxBuffer1[21];
					qj.c[2] = RxBuffer1[22];
					qj.c[1] = RxBuffer1[19];
					qj.c[0] = RxBuffer1[20];
					TestValue[4] = (long int)(qj.f * 10 + 0.5);	//Channel1#温度
					qj.c[3] = RxBuffer1[25];
					qj.c[2] = RxBuffer1[26];
					qj.c[1] = RxBuffer1[23];
					qj.c[0] = RxBuffer1[24];
					TestValue[5] = (long int)(qj.f * 10 + 0.5);	//Channel2#温度
					qj.c[3] = RxBuffer1[29];
					qj.c[2] = RxBuffer1[30];
					qj.c[1] = RxBuffer1[27];
					qj.c[0] = RxBuffer1[28];
					TestValue[6] = (long int)(qj.f * 10 + 0.5);	//Channel3#温度
					qj.c[3] = RxBuffer1[33];
					qj.c[2] = RxBuffer1[34];
					qj.c[1] = RxBuffer1[31];
					qj.c[0] = RxBuffer1[32];
					TestValue[7] = (long int)(qj.f * 10 + 0.5);	//Channel4#温度
					
					if(0 == workMode)	//反馈应变量
					{
						for(i = 0;i < 4;i++)
						{
							fCurrentMeasurement =  TestValue[i] ;
							fCurrentMeasurement = fCurrentMeasurement / 10;	//0.1Hz分辨率频率
							fCurrentMeasurement = fCurrentMeasurement * fCurrentMeasurement / 1000; //频模
							fCurrentMeasurement = (fCurrentMeasurement - FreMod) * 10 * (kindex.fkvalue)  * fCorrect;	//应变
							TestValue[i] = (int)(fCurrentMeasurement + 0.5);
						}
					}
					else if(1 == workMode)	//反馈频模
					{
						for(i = 0;i < 4;i++)
						{
							fCurrentMeasurement = TestValue[i] / 10;
							fCurrentMeasurement = fCurrentMeasurement * (fCurrentMeasurement / 100) * fCorrect;
							TestValue[i] = (int)(fCurrentMeasurement + 0.5);
						}
					}
					else if(2 == workMode)	//反馈频率
					{
						for(i = 0;i < 4;i++)
						{
							fCurrentMeasurement = TestValue[i] * fCorrect;
							TestValue[i] = (int)(fCurrentMeasurement + 0.5);
						}
					}
					break;
				}
			}
		}
	}

	if(j)
	{
		return 0;
	}
	else
	{
		return 1;
	}
}

int CheckBaudrate(void)
{
	if(baudcode2 >= '0' && baudcode2 <= '9')
	{
		return 0;
	}
	else if ((baudcode2 >= 'a' && baudcode2 <= 'd'))
	{
		return 0;
	}
	else if ((baudcode2 >= 'A' && baudcode2 <= 'D'))
	{
		return 0;
	}
	else
	{
		return -1;
	}
}
void RefreshBaudrate1()
{
	switch(baudcode2)
	{
		case '0' :
			UART2_BaudRate = 300 ;break;
		case '1' :
			UART2_BaudRate = 600 ;break;
		case '2' :
			UART2_BaudRate = 1200 ;break;
		case '3' :
			UART2_BaudRate = 1800 ;break;
		case '4' :
			UART2_BaudRate = 2400 ;break;
		case '5' :
			UART2_BaudRate = 4800 ;break;
		case '6' :
			UART2_BaudRate = 7200 ;break;
		case '7' :
			UART2_BaudRate = 9600 ;break;
		case '8' :
			UART2_BaudRate = 14400 ;break;
		case '9' :
			UART2_BaudRate = 19200 ;break;
		case 'a' :
		case 'A' :
			UART2_BaudRate = 38400 ;break;
		case 'b' :
		case 'B' :
			UART2_BaudRate = 57600 ;break;
		case 'c' :
		case 'C' :
			UART2_BaudRate = 115200 ;break;
		case 'd' :
		case 'D' :
			UART2_BaudRate = 128000 ;break;
		default:
			UART2_BaudRate = 19200 ;break;
	}
}

static void system_config_before_stop(void)
{
    GPIO_InitTypeDef GPIO_Initure;

    HAL_UART_DeInit(&huart1);
	HAL_UART_DeInit(&huart2);
	HAL_UART_DeInit(&hlpuart1);
    /* Enable Ultra low power mode */
    HAL_PWREx_EnableUltraLowPower();

    /* Enable the fast wake up from Ultra low power mode */
    HAL_PWREx_EnableFastWakeUp();

    /* Select MSI as system clock source after Wake Up from Stop mode */
    __HAL_RCC_WAKEUPSTOP_CLK_CONFIG(RCC_STOP_WAKEUPCLOCK_MSI);

    /* Enable GPIOs clock */
    __HAL_RCC_GPIOA_CLK_ENABLE();
    __HAL_RCC_GPIOB_CLK_ENABLE();
    __HAL_RCC_GPIOC_CLK_ENABLE();

    /* Configure all GPIO port pins in Analog Input mode (floating input trigger OFF) */
    GPIO_Initure.Pin = GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_7
    				| GPIO_PIN_8 | GPIO_PIN_9 | GPIO_PIN_10 | GPIO_PIN_11 | GPIO_PIN_12 | GPIO_PIN_13
    				| GPIO_PIN_14 | GPIO_PIN_15;
    GPIO_Initure.Mode = GPIO_MODE_ANALOG;
    GPIO_Initure.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(GPIOA, &GPIO_Initure);
    GPIO_Initure.Pin = GPIO_PIN_All;
    GPIO_Initure.Mode = GPIO_MODE_ANALOG;
    GPIO_Initure.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(GPIOB, &GPIO_Initure);
    HAL_GPIO_Init(GPIOC, &GPIO_Initure);

    /* Disable GPIOs clock */
    __HAL_RCC_GPIOA_CLK_DISABLE();
    __HAL_RCC_GPIOB_CLK_DISABLE();
    __HAL_RCC_GPIOC_CLK_DISABLE();
}

static void stop_exit_config(void)
{
    GPIO_InitTypeDef GPIO_Initure = {0};
    __HAL_RCC_GPIOA_CLK_ENABLE();
    __HAL_RCC_GPIOB_CLK_ENABLE();
	HAL_GPIO_WritePin(GPIOA,GPIO_PIN_5,GPIO_PIN_SET);
	HAL_GPIO_WritePin(GPIOA,GPIO_PIN_6,GPIO_PIN_RESET);
	GPIO_Initure.Pin = GPIO_PIN_5 | GPIO_PIN_6;	//M0M1
  	GPIO_Initure.Mode = GPIO_MODE_OUTPUT_PP;
	GPIO_Initure.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(GPIOA, &GPIO_Initure);
	HAL_Delay(10);
	GPIO_Initure.Pin = GPIO_PIN_15;
  	GPIO_Initure.Mode = GPIO_MODE_OUTPUT_PP;
	GPIO_Initure.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(GPIOB, &GPIO_Initure);
	//串口接收中断唤醒
	GPIO_Initure.Pin = GPIO_PIN_11;
	//GPIO_Initure.Mode = GPIO_MODE_IT_FALLING;
	GPIO_Initure.Mode = GPIO_MODE_IT_RISING_FALLING;
	GPIO_Initure.Pull = GPIO_PULLUP;
	HAL_GPIO_Init(GPIOB, &GPIO_Initure);
	
	HAL_NVIC_SetPriority(EXTI4_15_IRQn, 0, 0);
	HAL_NVIC_EnableIRQ(EXTI4_15_IRQn);
}

static void M0M1ModeConfig(void)
{
    GPIO_InitTypeDef GPIO_Initure = {0};
    __HAL_RCC_GPIOA_CLK_ENABLE();
	__HAL_RCC_GPIOB_CLK_ENABLE();

	HAL_GPIO_WritePin(GPIOA,GPIO_PIN_5,GPIO_PIN_SET);
	HAL_GPIO_WritePin(GPIOA,GPIO_PIN_6,GPIO_PIN_RESET); //5==1,6==0为进入接收模式
    GPIO_Initure.Pin = GPIO_PIN_5 | GPIO_PIN_6;	//M0M1
    GPIO_Initure.Mode = GPIO_MODE_OUTPUT_PP;
    GPIO_Initure.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(GPIOA, &GPIO_Initure);
	
	GPIO_Initure.Pin = GPIO_PIN_13;	
    GPIO_Initure.Mode = GPIO_MODE_OUTPUT_PP;
    GPIO_Initure.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(GPIOB, &GPIO_Initure);	
	GPIO_Initure.Pin = GPIO_PIN_15;	
    GPIO_Initure.Mode = GPIO_MODE_OUTPUT_PP;
    GPIO_Initure.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(GPIOB, &GPIO_Initure);
}

void mbs_init(MB_PARAM *port)
{
    port->rx_byte_cnt = 0;
    memset(port->rx_buf, 0x00, MB_BUF_SIZE);

    port->tx_byte_cnt = 0;
    memset(port->tx_buf, 0x00, MB_BUF_SIZE);

    port->rx_end_flg = 0;
    port->rx_timer_flg = 0;
    port->rx_timeout = 0;
}

